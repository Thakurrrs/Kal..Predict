# ---------------------------------------------------------------------------
# Kalshi API (read-only credential mode)
# ---------------------------------------------------------------------------
# Provide the private key ONE of two ways. Inline (KALSHI_PRIVATE_KEY_PEM)
# takes precedence over the path. The inline value IS the real secret:
# treat this whole file like the key itself and never paste it anywhere.
#
# Inline (recommended for this setup): paste the full PEM. Either keep real
# newlines (wrap the value in quotes) or use a single line with literal \n.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PEM=
# Fallback: path to an unencrypted RSA private key .pem file on disk.
# KALSHI_PRIVATE_KEY_PATH=/path/to/private_key.pem
# Override host for demo/sandbox vs production.
KALSHI_BASE_URL=https://external-api.kalshi.com

# ---------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data) - required for economics research
# ---------------------------------------------------------------------------
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org

# ---------------------------------------------------------------------------
# BLS (Bureau of Labor Statistics) - optional
# ---------------------------------------------------------------------------
BLS_API_KEY=
BLS_BASE_URL=https://api.bls.gov

# ---------------------------------------------------------------------------
# NWS (National Weather Service) - free, no auth
# ---------------------------------------------------------------------------
NWS_USER_AGENT=kal-predict/0.1.0

# ---------------------------------------------------------------------------
# Search providers (free tier)
# ---------------------------------------------------------------------------
SEARXNG_BASE_URL=http://localhost:8888
SEARXNG_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Ollama (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BRAIN_MODEL=phi4:14b
OLLAMA_HANDS_MODEL=qwen2.5-coder:7b
OLLAMA_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# Execution mode (keep paper until live readiness gate passes)
# ---------------------------------------------------------------------------
EXECUTION_MODE=paper
EXECUTION_TRADING_ENABLED=true
EXECUTION_CAPITAL_USD=10000
EXECUTION_MAX_POSITION_USD=1000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Risk gates
# ---------------------------------------------------------------------------
RISK_GATE_MIN_CONFIDENCE=0.55
RISK_GATE_MAX_LOSS_PER_TRADE_USD=500
RISK_GATE_DAILY_LOSS_LIMIT_USD=2000
